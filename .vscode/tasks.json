        "& 'C:\\Program Files\\MariaDB 12.3\\bin\\mariadbd.exe' --defaults-file='C:\\Program Files\\MariaDB 12.3\\data\\my.ini' --console"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
